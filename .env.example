# Copia a .env y rellena. El .env NUNCA se versiona.

# Puerto en el que el contenedor se publica en el host (http://localhost:HOST_PORT).
# Dentro del contenedor la app sigue escuchando en el 3000: esto solo cambia el de fuera.
# Sin Docker, el puerto lo fija PORT (3000 por defecto).
HOST_PORT=3000

# Token de API de jaso-rc. Lo genera el integrador con: jaso-rc -gen-token NOMBRE
# Vive solo en este servidor: es él quien pone el `Authorization: Bearer` al reenviar
# las llamadas del panel a la baseUrl del diseño. El navegador nunca lo ve.
# Sin él, los paneles reciben 503 al pulsar cualquier botón.
JASO_RC_TOKEN=

# `true` si jaso-rc sirve HTTPS con un certificado autofirmado (lo habitual en una LAN
# de control). Desactiva la validación TLS de todo el proceso: no lo pongas si el
# servidor habla con algo más que jaso-rc.
JASO_RC_INSECURE_TLS=false

# Contraseña del editor (http://localhost:3000/). Sin ella el editor queda ABIERTO a
# cualquiera que llegue al puerto, y el servidor lo avisa al arrancar.
# Los paneles generados (/designs/…) NO piden contraseña: una tablet en la pared no
# puede escribirla.
EDITOR_PASSWORD=

# Caducidad absoluta de la sesión del editor, en horas (por defecto 12). No es deslizante:
# pasado ese plazo hay que volver a entrar aunque hayas estado trabajando.
EDITOR_SESSION_TTL_HOURS=12

# `true` si sirves el editor por HTTPS: marca la cookie de sesión como Secure.
EDITOR_SECURE_COOKIES=false
